___SANDBOXED_JS_FOR_SERVER___

const sendHttpRequest = require('sendHttpRequest');
const getEventData = require('getEventData');
const JSON = require('JSON');
const logToConsole = require('logToConsole');
const getRemoteAddress = require('getRemoteAddress');
const getUserAgent = require('getUserAgent');

const accountId = data.accountId;
const userId = getEventData('user_id');
const sgtmEvent = getEventData('event_name');

const eventTypeMap = {
  page_view: 'PAGE_VIEW',
  view_item: 'PRODUCT_VIEW',
  view_item_list: 'CATEGORY_VIEW',
  add_to_cart: 'ADD_TO_CART',
  add_to_wishlist: 'ADD_TO_WISH_LIST',
  begin_checkout: 'CHECKOUT',
  purchase: 'PURCHASE',
  search: 'SEARCH'
};

const tbEvent = eventTypeMap[sgtmEvent];
if (!tbEvent || !userId) {
  data.gtmOnSuccess();
  return;
}

// --- Build context ---
const context = {
  ce: 'ecomm',
  ui: userId,
  externalId: true,
  gdpr: '' + (getEventData('gdpr') || '0'),
  cex: getEventData('cex') || 'true'
};

const unifiedId = getEventData('unified_id');
if (unifiedId) context.unified_id = unifiedId;

const tblci = getEventData('tblci');
if (tblci) context.tblci = tblci;

const cnxclid = getEventData('cnxclid');
if (cnxclid) context.cnxclid = cnxclid;

const custType = getEventData('cust_type');
if (custType) context.custType = '' + custType;

const pageUrl = getEventData('page_location');
if (pageUrl) context['item-url'] = pageUrl;

const referrer = getEventData('page_referrer');
if (referrer) context.ref = referrer;

const ip = getRemoteAddress();
if (ip) context.ip = ip;

const ua = getUserAgent();
if (ua) context.userAgent = ua;

// --- Build event ---
const eventEntry = { en: tbEvent };
const items = getEventData('items') || [];

if (tbEvent === 'PAGE_VIEW') {
  // No data needed
}
else if (tbEvent === 'PRODUCT_VIEW' ||
         tbEvent === 'ADD_TO_CART' ||
         tbEvent === 'ADD_TO_WISH_LIST') {
  eventEntry.data = {
    productIds: items.map(function(it) {
      return '' + it.item_id;
    })
  };
}
else if (tbEvent === 'CATEGORY_VIEW') {
  eventEntry.data = {
    category: getEventData('item_list_name') || '',
    productIds: items.slice(0, 5).map(function(it) {
      return '' + it.item_id;
    })
  };
}
else if (tbEvent === 'SEARCH') {
  eventEntry.data = {
    searchTerm: getEventData('search_term') || '',
    productIds: items.slice(0, 5).map(function(it) {
      return '' + it.item_id;
    })
  };
}
else if (tbEvent === 'CHECKOUT') {
  eventEntry.data = {
    productIds: items.map(function(it) {
      return '' + it.item_id;
    })
  };
}
else if (tbEvent === 'PURCHASE') {
  eventEntry.data = {
    orderId: getEventData('transaction_id') || '',
    value: '' + (getEventData('value') || '0'),
    currency: getEventData('currency') || 'USD',
    cartDetails: items.map(function(it) {
      return {
        productId: '' + it.item_id,
        quantity: it.quantity || 1,
        price: '' + it.price || '0'
      };
    })
  };
}

// --- Send request ---
const payload = {
  context: context,
  events: [eventEntry]
};

logToConsole('Taboola DCO payload: ' + JSON.stringify(payload));

sendHttpRequest(
  'https://trc.taboola.com/' + accountId +
    '/log/3/unip?bulk=true&bulk-ce=dco',
  function(statusCode) {
    if (statusCode >= 200 && statusCode < 300) {
      data.gtmOnSuccess();
    } else {
      data.gtmOnFailure();
    }
  },
  {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    timeout: 5000
  },
  JSON.stringify(payload)
);


